{
  "name": "template-web-service",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node server.ts",
    "start": "NODE_ENV=production node server.ts",
    "build": "pnpm run build:client && pnpm run build:server",
    "build:client": "NODE_ENV=production vite build --outDir dist/client --ssrManifest",
    "build:server": "NODE_ENV=production vite build --outDir dist/server --ssr src/entry-server.tsx",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fastify/compress": "^8",
    "@fastify/middie": "^9",
    "@fastify/static": "^8",
    "fastify": "^5",
    "react": "catalog:react",
    "react-dom": "catalog:react"
  },
  "devDependencies": {
    "@eslint/js": "catalog:eslint",
    "@types/node": "catalog:typescript",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@vitejs/plugin-react": "catalog:vite",
    "eslint": "catalog:eslint",
    "eslint-plugin-react-hooks": "catalog:eslint",
    "eslint-plugin-react-refresh": "catalog:eslint",
    "globals": "catalog:eslint",
    "tsx": "^4",
    "typescript": "catalog:typescript",
    "typescript-eslint": "catalog:eslint",
    "vite": "catalog:vite"
  }
}
